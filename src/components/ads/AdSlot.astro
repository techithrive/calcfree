---
/**
 * AdSlot — a layout-stable advertising slot.
 *
 * Behaviour:
 * - Always reserves height (via the .ad-slot CSS) so there is no layout shift,
 *   whether or not an ad loads.
 * - Renders the real AdSense <ins> unit ONLY when a publisher ID is set in CMS
 *   settings (i.e. after approval) AND a slotId is provided. Before that it is
 *   an empty reserved space — nothing loads, nothing is mislabelled.
 *
 * Placement rules (enforced by the page layouts, not here): never between a
 * calculator input and its result, never above the H1, never dominating content.
 */
import { getEntry } from 'astro:content';

interface Props {
  /** AdSense ad unit slot ID (data-ad-slot). Omit pre-approval. */
  slotId?: string;
  /** Visual reserve size. */
  size?: 'leaderboard' | 'rectangle' | 'in-feed';
  format?: string;
}

const { slotId, size = 'in-feed', format = 'auto' } = Astro.props;

const settings = await getEntry('settings', 'settings');
const pub = settings?.data.adsense_publisher_id?.trim();
const live = Boolean(pub && slotId);
---

<div class="ad-slot" data-size={size} aria-hidden={live ? undefined : 'true'}>
  {live ? (
    <ins
      class="adsbygoogle"
      style="display:block;width:100%"
      data-ad-client={pub}
      data-ad-slot={slotId}
      data-ad-format={format}
      data-full-width-responsive="true"
    ></ins>
    <script is:inline>
      (adsbygoogle = window.adsbygoogle || []).push({});
    </script>
  ) : (
    <span class="visually-hidden">Advertisement space</span>
  )}
</div>
