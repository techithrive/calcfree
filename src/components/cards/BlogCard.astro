---
/**
 * BlogCard — blog index, homepage "latest", related posts. Shows a real
 * featured image when provided; falls back to a branded tinted icon band.
 */
import Icon from '../ui/Icon.astro';

interface Props {
  title: string;
  href: string;
  excerpt?: string;
  date?: Date | string;
  author?: string;
  category?: string;
  icon?: string;
  image?: string;
}

const { title, href, excerpt, date, author, category, icon = 'doc', image } = Astro.props;

let dateLabel = '';
if (date) {
  const d = date instanceof Date ? date : new Date(date);
  if (!isNaN(d.valueOf())) {
    dateLabel = d.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' });
  }
}
---

<a class="card card-link post" href={href}>
  {image ? (
    <img class="post-img" src={image} alt="" width="800" height="450" loading="lazy" decoding="async" />
  ) : (
    <span class="post-thumb" aria-hidden="true"><Icon name={icon} size={30} /></span>
  )}
  <div class="post-body">
    {category && <span class="post-cat">{category}</span>}
    <h3>{title}</h3>
    {excerpt && <p>{excerpt}</p>}
    {(dateLabel || author) && (
      <p class="post-meta muted">
        {author && <span>{author}</span>}
        {author && dateLabel && <span aria-hidden="true"> · </span>}
        {dateLabel && <time>{dateLabel}</time>}
      </p>
    )}
  </div>
</a>

<style>
  .post { padding: 0; overflow: hidden; display: flex; flex-direction: column; }
  .post-img {
    width: 100%; height: 168px; object-fit: cover; display: block;
    border-bottom: 1px solid var(--line); background: var(--accent-tint);
  }
  .post-thumb {
    display: flex; align-items: center; justify-content: center; height: 96px;
    background: radial-gradient(200px 120px at 70% 0%, var(--accent-tint-2) 0%, transparent 70%), var(--accent-tint);
    color: var(--accent-strong); border-bottom: 1px solid var(--line);
  }
  .post-body { padding: var(--sp-5); }
  .post-cat {
    display: inline-block; font-size: var(--fs-200); font-weight: 700; letter-spacing: 0.05em;
    text-transform: uppercase; color: var(--accent-strong); margin-bottom: var(--sp-2);
  }
  .post h3 { margin: 0 0 var(--sp-1); font-size: var(--fs-500); }
  .post-meta { margin-top: var(--sp-3); font-size: var(--fs-300); }
</style>
