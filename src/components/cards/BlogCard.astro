---
/**
 * BlogCard — used on the blog index, homepage "latest from the blog" and
 * related-posts sections. Date is pre-formatted by the parent or formatted here
 * with a simple en-GB fallback.
 */
interface Props {
  title: string;
  href: string;
  excerpt?: string;
  date?: Date | string;
  author?: string;
}

const { title, href, excerpt, date, author } = Astro.props;

let dateLabel = '';
if (date) {
  const d = date instanceof Date ? date : new Date(date);
  if (!isNaN(d.valueOf())) {
    dateLabel = d.toLocaleDateString('en-GB', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    });
  }
}
---

<a class="card card-link post" href={href}>
  <h3>{title}</h3>
  {excerpt && <p>{excerpt}</p>}
  {(dateLabel || author) && (
    <p class="post-meta muted text-sm">
      {author && <span>{author}</span>}
      {author && dateLabel && <span aria-hidden="true"> · </span>}
      {dateLabel && <time>{dateLabel}</time>}
    </p>
  )}
</a>

<style>
  .post h3 {
    margin-bottom: var(--sp-1);
  }
  .post-meta {
    margin-top: var(--sp-2);
  }
</style>
