---
/**
 * CategoryCard — used in the homepage category explorer and cross-links.
 * `icon` is a token resolved by the Icon component (tax, finance, home, etc.).
 */
import Icon from '../ui/Icon.astro';

interface Props {
  title: string;
  href: string;
  description?: string;
  icon?: string;
  count?: number;
}

const { title, href, description, icon = 'calculator', count } = Astro.props;
---

<a class="card card-link card-tool cat" href={href}>
  <span class="card-icon" aria-hidden="true"><Icon name={icon} size={24} /></span>
  <h3>{title}</h3>
  {description && <p>{description}</p>}
  <span class="card-cue">{count ? `${count} tools` : 'Explore'}</span>
</a>

<style>
  .cat h3 {
    margin: 0;
  }
</style>
