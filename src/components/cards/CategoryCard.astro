---
/**
 * CategoryCard — homepage category explorer + cross-links. Shows a branded
 * image band when provided, otherwise an icon tile. `count` shows tool count.
 */
import Icon from '../ui/Icon.astro';

interface Props {
  title: string;
  href: string;
  description?: string;
  icon?: string;
  count?: number;
  image?: string;
}

const { title, href, description, icon = 'calculator', count, image } = Astro.props;
---

<a class="card card-link cat" href={href}>
  {image ? (
    <img class="cat-img" src={image} alt="" width="800" height="500" loading="lazy" decoding="async" />
  ) : (
    <span class="card-icon" aria-hidden="true"><Icon name={icon} size={24} /></span>
  )}
  <div class="cat-body">
    <h3>{title}</h3>
    {description && <p>{description}</p>}
    <span class="card-cue">{count ? `${count} tools` : 'Explore'}</span>
  </div>
</a>

<style>
  .cat { padding: 0; overflow: hidden; display: flex; flex-direction: column; }
  .cat-img {
    width: 100%; height: 150px; object-fit: cover; display: block;
    border-bottom: 1px solid var(--line);
  }
  .cat-body { padding: var(--sp-5); display: flex; flex-direction: column; gap: var(--sp-2); flex: 1; }
  .cat-body h3 { margin: 0; }
  .cat .card-icon { margin: var(--sp-5) var(--sp-5) 0; }
</style>
