---
/**
 * AnnouncementBar — a slim bar above the header with rotating trust messages.
 * Pure CSS rotation (no JS), so it never blocks render or causes layout shift.
 * Messages are professional, factual trust signals — not promotional.
 */
const messages = [
  'Updated for the latest UK tax rules',
  'HMRC-based calculations',
  'Free calculators — no signup',
  'Sources and assumptions shown',
];
---

<div class="announce" role="region" aria-label="Site highlights">
  <div class="container announce-inner">
    <ul class="announce-rotator" aria-hidden="false">
      {messages.map((m) => (
        <li><span class="announce-dot" aria-hidden="true"></span>{m}</li>
      ))}
    </ul>
  </div>
</div>

<style>
  .announce {
    background: var(--ink);
    color: #fff;
    font-size: var(--fs-300);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  .announce-inner {
    height: 36px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .announce-rotator {
    list-style: none;
    margin: 0;
    padding: 0;
    position: relative;
    width: 100%;
    height: 36px;
  }
  .announce-rotator li {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    justify-content: center;
    opacity: 0;
    font-weight: 500;
    letter-spacing: 0.01em;
    animation: announce-cycle 16s infinite;
  }
  .announce-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-soft);
    flex: 0 0 auto;
  }
  .announce-rotator li:nth-child(1) { animation-delay: 0s; }
  .announce-rotator li:nth-child(2) { animation-delay: 4s; }
  .announce-rotator li:nth-child(3) { animation-delay: 8s; }
  .announce-rotator li:nth-child(4) { animation-delay: 12s; }

  @keyframes announce-cycle {
    0% { opacity: 0; transform: translateY(8px); }
    3% { opacity: 1; transform: translateY(0); }
    22% { opacity: 1; transform: translateY(0); }
    25% { opacity: 0; transform: translateY(-8px); }
    100% { opacity: 0; }
  }

  /* On desktop, show messages inline rather than rotating — calmer, more premium */
  @media (min-width: 720px) {
    .announce-rotator {
      display: flex;
      justify-content: center;
      gap: var(--sp-6);
      height: 36px;
    }
    .announce-rotator li {
      position: static;
      inset: auto;
      opacity: 1;
      animation: none;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .announce-rotator li { animation: none; opacity: 1; }
    .announce-rotator li:nth-child(n+2) { display: none; }
  }
</style>
