---
/**
 * Site header: logo + nav (Categories mega-menu, Tools, Blog, About, Contact)
 * + Search + "Browse tools" CTA. No-JS friendly: the Categories dropdown and
 * the mobile menu are native <details> disclosures. All links are crawlable.
 */
import Icon from '../ui/Icon.astro';
import { getCollection } from 'astro:content';
import { activeCategories, categoryHref, toolHref, blogHref } from '../../lib/internal-links';

const cats = await activeCategories(1);
const allTools = await getCollection('tools', ({ data }) => !data.draft);
const menu = cats.map((c) => ({
  title: c.data.title,
  href: categoryHref(c),
  icon: c.data.icon ?? 'calculator',
  tools: allTools
    .filter((t) => t.data.category?.id === c.id)
    .slice(0, 6)
    .map((t) => ({ title: t.data.title, href: toolHref(t) })),
}));

// Popular tools (first few) + latest guides for the mega-menu's right rail.
const popular = allTools.slice(0, 4).map((t) => ({ title: t.data.title, href: toolHref(t) }));
const latestGuides = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => (b.data.published_date?.valueOf() ?? 0) - (a.data.published_date?.valueOf() ?? 0))
  .slice(0, 3)
  .map((p) => ({ title: p.data.title, href: blogHref(p) }));
---

<header class="site-header">
  <div class="container bar">
    <a class="brand" href="/" aria-label="CalcFree home">
      <img src="/logo.svg" alt="CalcFree" width="150" height="30" />
    </a>

    <!-- Desktop nav -->
    <nav class="nav-desktop" aria-label="Primary">
      <details class="mega">
        <summary>Categories <span class="caret" aria-hidden="true">▾</span></summary>
        <div class="mega-panel">
          {menu.map((c) => (
            <div class="mega-col">
              <a class="mega-cat" href={c.href}><span class="mega-ic"><Icon name={c.icon} size={18} /></span>{c.title}</a>
              <ul>
                {c.tools.map((t) => (<li><a href={t.href}>{t.title}</a></li>))}
                <li><a class="mega-all" href={c.href}>All {c.title} →</a></li>
              </ul>
            </div>
          ))}
          <div class="mega-col mega-rail">
            <p class="mega-rail-h">Popular tools</p>
            <ul>
              {popular.map((t) => (<li><a href={t.href}>{t.title}</a></li>))}
            </ul>
            <p class="mega-rail-h">Latest guides</p>
            <ul>
              {latestGuides.map((g) => (<li><a href={g.href}>{g.title}</a></li>))}
            </ul>
          </div>
        </div>
      </details>
      <a href="/tools/">Tools</a>
      <a href="/blog/">Blog</a>
      <a href="/about/">About</a>
      <a href="/contact/">Contact</a>
    </nav>

    <div class="nav-actions">
      <a class="nav-search-btn" href="/search/" aria-label="Search"><Icon name="search" size={20} /></a>
      <a class="btn btn-primary nav-cta" href="/tools/">Browse tools</a>

      <!-- Mobile menu -->
      <details class="nav-mobile">
        <summary aria-label="Toggle menu"><span class="burger" aria-hidden="true"></span></summary>
        <nav class="mobile-panel" aria-label="Mobile">
          <a href="/tools/">Tools</a>
          <details class="mobile-cats">
            <summary>Categories</summary>
            <ul>
              {menu.map((c) => (<li><a href={c.href}>{c.title}</a></li>))}
            </ul>
          </details>
          <a href="/blog/">Blog</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
          <a href="/search/">Search</a>
          <a class="btn btn-primary btn-block" href="/tools/" style="margin-top: var(--sp-2);">Browse tools</a>
        </nav>
      </details>
    </div>
  </div>
</header>

<style>
  .site-header .bar { gap: var(--sp-5); }
  .nav-actions { display: flex; align-items: center; gap: var(--sp-3); }

  /* ----- Desktop nav ----- */
  .nav-desktop { display: none; align-items: center; gap: var(--sp-5); margin-left: auto; }
  .nav-desktop > a, .mega > summary {
    color: var(--ink-soft); text-decoration: none; font-weight: 500; cursor: pointer;
    list-style: none; display: inline-flex; align-items: center; gap: 0.3rem;
  }
  .nav-desktop > a:hover, .mega > summary:hover { color: var(--accent-strong); }
  .mega { position: relative; }
  .mega > summary::-webkit-details-marker { display: none; }
  .mega .caret { font-size: 0.7em; transition: transform 0.15s ease; }
  .mega[open] .caret, .mega:hover .caret { transform: rotate(180deg); }
  .mega-panel {
    position: absolute; left: 50%; transform: translateX(-50%); top: calc(100% + 14px);
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-raised); padding: var(--sp-5); z-index: 70;
    display: grid; grid-template-columns: repeat(3, minmax(200px, 1fr)); gap: var(--sp-6);
    width: max-content; max-width: 760px;
  }
  /* Open on hover (desktop) and on click (keyboard/touch via <details open>). */
  .mega:not([open]) .mega-panel { display: none; }
  .mega:hover .mega-panel { display: grid; }
  .mega-cat { display: flex; align-items: center; gap: 0.5rem; font-weight: 700; color: var(--ink); text-decoration: none; margin-bottom: var(--sp-2); }
  .mega-ic { color: var(--accent-strong); display: inline-flex; }
  .mega-col ul { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.45rem; }
  .mega-col a { color: var(--ink-soft); text-decoration: none; font-size: 0.93rem; }
  .mega-col a:hover { color: var(--accent-strong); }
  .mega-all { font-weight: 600; color: var(--accent-strong) !important; }
  .mega-rail { border-left: 1px solid var(--line); padding-left: var(--sp-5); }
  .mega-rail-h { font-size: var(--fs-200); font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--ink-muted); margin: 0 0 var(--sp-2); }
  .mega-rail ul { margin-bottom: var(--sp-4); }

  .nav-search-btn {
    display: none; align-items: center; justify-content: center;
    width: 42px; height: 42px; border-radius: var(--radius-sm);
    border: 1px solid var(--line-strong); color: var(--ink-soft);
  }
  .nav-search-btn:hover { border-color: var(--ink-muted); color: var(--accent-strong); }
  .nav-cta { display: none; }

  /* ----- Mobile menu: compact, right-aligned ----- */
  .nav-mobile { position: relative; }
  .nav-mobile > summary {
    list-style: none; cursor: pointer; display: inline-flex; align-items: center;
    width: 42px; height: 42px; justify-content: center;
    border: 1px solid var(--line-strong); border-radius: var(--radius-sm);
  }
  .nav-mobile > summary::-webkit-details-marker { display: none; }
  .burger, .burger::before, .burger::after { display: block; width: 18px; height: 2px; background: var(--ink); position: relative; }
  .burger::before, .burger::after { content: ''; position: absolute; left: 0; }
  .burger::before { top: -6px; } .burger::after { top: 6px; }
  .mobile-panel {
    position: absolute; right: 0; top: calc(100% + 10px);
    background: var(--surface); border: 1px solid var(--line); border-radius: var(--radius);
    box-shadow: var(--shadow); padding: var(--sp-4); min-width: 220px; max-width: 80vw;
    display: flex; flex-direction: column; gap: var(--sp-3); z-index: 70;
  }
  .mobile-panel > a { color: var(--ink-soft); text-decoration: none; font-weight: 500; }
  .mobile-panel > a:hover { color: var(--accent-strong); }
  .mobile-cats > summary { cursor: pointer; font-weight: 500; color: var(--ink-soft); list-style: none; }
  .mobile-cats > summary::-webkit-details-marker { display: none; }
  .mobile-cats ul { list-style: none; margin: var(--sp-2) 0 0; padding: 0 0 0 var(--sp-3); display: flex; flex-direction: column; gap: var(--sp-2); border-left: 2px solid var(--line); }
  .mobile-cats a { color: var(--ink-muted); text-decoration: none; font-size: 0.92rem; }

  @media (min-width: 900px) {
    .nav-desktop { display: flex; }
    .nav-search-btn { display: inline-flex; }
    .nav-cta { display: inline-flex; }
    .nav-mobile { display: none; }
  }
</style>
