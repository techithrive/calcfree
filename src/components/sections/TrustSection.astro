---
/**
 * TrustSection — honest, specific reasons to trust the tools, each with an icon.
 * No superlatives, no fake stats. Icon token comes from each point's `icon`.
 */
import Icon from '../ui/Icon.astro';

interface TrustPoint {
  heading: string;
  text: string;
  icon?: string;
}

interface Props {
  heading?: string;
  intro?: string;
  points: TrustPoint[];
}

const {
  heading = 'Why people trust CalcFree',
  intro = 'No black-box numbers. Every tool shows its working, names its source, and tells you what it assumes.',
  points,
} = Astro.props;

const iconFor = (token?: string) =>
  token && ['lock', 'source', 'calendar', 'shield', 'check'].includes(token) ? token : 'check';
---

<section class="section trust">
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Trust &amp; transparency</span>
      <h2>{heading}</h2>
      {intro && <p class="lead">{intro}</p>}
    </div>
    <div class="trust-grid">
      {points.map((p) => (
        <div class="trust-item">
          <span class="trust-icon"><Icon name={iconFor(p.icon)} size={22} /></span>
          <h3>{p.heading}</h3>
          <p class="muted">{p.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
