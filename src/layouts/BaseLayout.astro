---
/**
 * BaseLayout — the HTML shell for every page.
 *
 * SEO meta (title, description, canonical, OpenGraph, Twitter) is delegated to
 * <SeoHead /> so there is a single source of truth and no duplicated tags.
 * Site-wide Organization JSON-LD is emitted here on every page. The AdSense
 * loader and structural tags (charset, viewport, favicon, theme-color) stay
 * here. A named "head" slot lets pages add page-specific schema (WebApplication,
 * Article, FAQ, Breadcrumb).
 */
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import AnnouncementBar from '../components/layout/AnnouncementBar.astro';
import Footer from '../components/layout/Footer.astro';
import SeoHead from '../components/seo/SeoHead.astro';
import SchemaOrganization from '../components/seo/SchemaOrganization.astro';
import { getEntry } from 'astro:content';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage,
  ogType = 'website',
  noindex = false,
} = Astro.props;

// Only the AdSense publisher ID is needed here; SeoHead reads the rest.
const settings = await getEntry('settings', 'settings');
const adsensePub = settings?.data.adsense_publisher_id?.trim();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
    />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="theme-color" content="#16161f" />

    {/* Site-wide Organization schema on every page */}
    <SchemaOrganization />

    {/* AdSense loader is only added once a publisher ID is set in CMS settings
        (i.e. after approval). Nothing loads before then. */}
    {adsensePub && (
      <script
        is:inline
        async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsensePub}`}
        crossorigin="anonymous"
      ></script>
    )}

    {/* Page-specific schema (WebApplication / Article / FAQ / Breadcrumb) */}
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <AnnouncementBar />
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
