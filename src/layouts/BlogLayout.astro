---
/**
 * BlogLayout — scaffold for an article. The route passes metadata + resolved
 * relations and renders the markdown body into the default slot.
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import type { Crumb } from '../components/layout/Breadcrumbs.astro';
import FaqBlock from '../components/sections/FaqBlock.astro';
import KeyTakeaways from '../components/sections/KeyTakeaways.astro';
import RelatedTools from '../components/sections/RelatedTools.astro';
import RelatedBlogs from '../components/sections/RelatedBlogs.astro';
import AdSlot from '../components/ads/AdSlot.astro';
import Icon from '../components/ui/Icon.astro';
import type { ToolCardData } from '../components/sections/FeaturedTools.astro';
import type { BlogCardData } from '../components/sections/RelatedBlogs.astro';

interface Props {
  seo: { title: string; description?: string; canonical?: string; ogImage?: string; noindex?: boolean };
  breadcrumbs: Crumb[];
  title: string;
  author?: { name: string; href: string; role?: string };
  publishedDate?: Date;
  updatedDate?: Date;
  quickAnswer?: string;
  keyTakeaways?: string[];
  readingMinutes?: number;
  sourcesCount?: number;
  faqs?: { question: string; answer: string }[];
  relatedTools?: ToolCardData[];
  relatedBlogs?: BlogCardData[];
}

const {
  seo,
  breadcrumbs,
  title,
  author,
  publishedDate,
  updatedDate,
  quickAnswer,
  keyTakeaways = [],
  readingMinutes,
  sourcesCount,
  faqs = [],
  relatedTools = [],
  relatedBlogs = [],
} = Astro.props;

const fmt = (d?: Date) =>
  d ? d.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' }) : null;
const published = fmt(publishedDate);
const updated = fmt(updatedDate);
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogImage={seo.ogImage}
  ogType="article"
  noindex={seo.noindex}
>
  <slot name="head" slot="head" />

  <Breadcrumbs items={breadcrumbs} />

  <!-- Article hero band -->
  <div class="article-hero">
    <div class="container container-reading">
      <span class="eyebrow">Guide</span>
      <h1>{title}</h1>
      <p class="article-meta">
        {author && <>By <a href={author.href}>{author.name}</a>{author.role ? `, ${author.role}` : ''}. </>}
        {published && <>Published {published}. </>}
        {updated && updated !== published && <>Updated {updated}.</>}
      </p>
      <ul class="article-trust" aria-label="Article details">
        {readingMinutes && <li><Icon name="doc" size={15} /> {readingMinutes} min read</li>}
        {(updated || published) && <li><Icon name="calendar" size={15} /> Reviewed {updated ?? published}</li>}
        {sourcesCount ? <li><Icon name="source" size={15} /> {sourcesCount} source{sourcesCount === 1 ? '' : 's'} cited</li> : null}
        <li><Icon name="shield" size={15} /> Checked against HMRC guidance</li>
      </ul>
    </div>
  </div>

  <article class="section" style="padding-top: var(--sp-6);">
    <div class="container container-reading">
      <slot name="hero-image" />

      {quickAnswer && (
        <div class="callout" style="margin-top: 0;">
          <strong>In short:</strong> {quickAnswer}
        </div>
      )}

      <KeyTakeaways points={keyTakeaways} />

      <AdSlot size="leaderboard" />

      <div class="prose" style="margin-top: var(--sp-5);">
        <slot />
      </div>
    </div>
  </article>

  <FaqBlock faqs={faqs} />

  <RelatedTools heading="Tools mentioned" tools={relatedTools} />
  <RelatedBlogs posts={relatedBlogs} />

  {author && (
    <section class="section" style="padding-top:0;">
      <div class="container container-reading">
        <div class="author-box">
          <div class="author-avatar" aria-hidden="true">{author.name.slice(0, 1)}</div>
          <div>
            <p style="margin:0;"><strong>{author.name}</strong>{author.role ? ` — ${author.role}` : ''}</p>
            <p style="margin-top: var(--sp-1); color: var(--ink-soft); font-size: 0.95rem;">
              Calculations reviewed against official HMRC, CRA and ATO guidance.
              <a href={author.href}>More from this author →</a>
            </p>
          </div>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .article-hero {
    background:
      radial-gradient(680px 260px at 80% -25%, var(--accent-tint) 0%, transparent 65%),
      var(--surface-warm);
    border-bottom: 1px solid var(--line);
    padding-block: var(--sp-7) var(--sp-6);
  }
  .article-hero h1 { margin: 0; }
  .article-featured {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-lg);
    border: 1px solid var(--line);
    margin-bottom: var(--sp-5);
    background: var(--accent-tint);
  }
  .article-meta {
    margin-top: var(--sp-3);
    color: var(--ink-muted);
    font-size: 0.95rem;
  }
  .article-trust {
    list-style: none;
    margin: var(--sp-4) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
  }
  .article-trust li {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: var(--fs-300);
    font-weight: 600;
    color: var(--ink-soft);
  }
  .article-trust svg { color: var(--accent-strong); }
  .author-box {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
    background: var(--surface-tint);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: var(--sp-5);
  }
  .author-avatar {
    flex: 0 0 auto;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--accent);
    color: #fff;
    display: grid;
    place-items: center;
    font-weight: 700;
    font-size: 1.2rem;
  }
  .author-box a { color: var(--accent-strong); text-decoration: none; font-weight: 600; }
  .author-box a:hover { text-decoration: underline; }
</style>
