---
/**
 * ToolLayout — the scaffold for a calculator page. It is presentational: the
 * page route (Batch 4) resolves content + references and passes them in, and
 * provides the calculator UI via the named "calculator" slot and the rendered
 * markdown body via the default slot.
 *
 * Order on the page:
 *   breadcrumbs → H1 + intro → quick answer → [ad] → calculator + result
 *   → [ad] → assumptions + source → body (default slot) → FAQ
 *   → related tools → related blogs → author + last updated
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/layout/Breadcrumbs.astro';
import type { Crumb } from '../components/layout/Breadcrumbs.astro';
import FaqBlock from '../components/sections/FaqBlock.astro';
import KeyTakeaways from '../components/sections/KeyTakeaways.astro';
import RelatedTools from '../components/sections/RelatedTools.astro';
import RelatedBlogs from '../components/sections/RelatedBlogs.astro';
import AdSlot from '../components/ads/AdSlot.astro';
import type { ToolCardData } from '../components/sections/FeaturedTools.astro';
import type { BlogCardData } from '../components/sections/RelatedBlogs.astro';

interface Props {
  seo: { title: string; description?: string; canonical?: string; ogImage?: string; noindex?: boolean };
  breadcrumbs: Crumb[];
  h1: string;
  intro?: string;
  quickAnswer?: string;
  keyTakeaways?: string[];
  sourceLabel?: string;
  sourceUrl?: string;
  faqs?: { question: string; answer: string }[];
  relatedTools?: ToolCardData[];
  relatedBlogs?: BlogCardData[];
  author?: { name: string; href: string; role?: string };
  lastReviewed?: Date;
  adSlots?: string[];
}

const {
  seo,
  breadcrumbs,
  h1,
  intro,
  quickAnswer,
  keyTakeaways = [],
  sourceLabel,
  sourceUrl,
  faqs = [],
  relatedTools = [],
  relatedBlogs = [],
  author,
  lastReviewed,
  adSlots = ['after-intro', 'after-result'],
} = Astro.props;

const show = (slot: string) => adSlots.includes(slot);

const reviewedLabel = lastReviewed
  ? lastReviewed.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogImage={seo.ogImage}
  ogType="website"
  noindex={seo.noindex}
>
  <slot name="head" slot="head" />

  <Breadcrumbs items={breadcrumbs} />

  <!-- Tool hero band: intro left, calculator right (above the fold) -->
  <div class="tool-hero">
    <div class="container tool-hero-grid">
      <div class="tool-hero-intro">
        <span class="eyebrow">Calculator</span>
        <h1>{h1}</h1>
        {intro && <p class="lead">{intro}</p>}
        {quickAnswer && (
          <div class="callout" style="margin-top: var(--sp-4);">
            <strong>In short:</strong> {quickAnswer}
          </div>
        )}
      </div>
      <div class="tool-hero-calc">
        <h2 class="calc-heading">Try the calculator</h2>
        <slot name="calculator" />
      </div>
    </div>
  </div>

  <article class="section" style="padding-top: var(--sp-6);">
    <div class="container container-narrow">
      <KeyTakeaways points={keyTakeaways} />

      {show('after-result') && <AdSlot size="rectangle" />}

      {/* Assumptions + source */}
      <div class="callout callout-assume" style="margin-top: var(--sp-5);">
        <p style="margin:0 0 var(--sp-2);"><strong>What this assumes</strong></p>
        <div class="prose"><slot name="assumptions" /></div>
        {sourceUrl && (
          <p style="margin-top: var(--sp-3); margin-bottom:0;">
            Source:&nbsp;
            <a href={sourceUrl} rel="noopener" target="_blank">{sourceLabel ?? 'Official source'}</a>
          </p>
        )}
        <p class="disclaimer" style="margin-top: var(--sp-3);">
          This is an estimate to help you plan, not financial, tax or legal advice.
        </p>
      </div>

      {/* Long-form explainer body */}
      <div class="prose" style="margin-top: var(--sp-7);">
        <slot />
      </div>

      {show('mid-content') && <AdSlot size="in-feed" />}
    </div>
  </article>

  <FaqBlock faqs={faqs} />

  <RelatedTools tools={relatedTools} />
  <RelatedBlogs heading="Related reading" posts={relatedBlogs} />

  {(author || reviewedLabel) && (
    <section class="section" style="padding-top:0;">
      <div class="container">
        <p class="updated">
          {author && (
            <>Written by <a href={author.href}>{author.name}</a>{author.role ? `, ${author.role}` : ''}. </>
          )}
          {reviewedLabel && <>Last reviewed {reviewedLabel}.</>}
        </p>
      </div>
    </section>
  )}
</BaseLayout>

<script>
  // Progressive enhancement: wire the static calculator form to its logic.
  import '../scripts/calculator-runtime';
</script>
