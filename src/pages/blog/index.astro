---
/**
 * Blog index. Lists all published posts (drafts excluded), newest first.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/layout/Breadcrumbs.astro';
import BlogCard from '../../components/cards/BlogCard.astro';
import SchemaBreadcrumb from '../../components/seo/SchemaBreadcrumb.astro';
import { getCollection, getEntry } from 'astro:content';
import { blogHref } from '../../lib/internal-links';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) =>
    (b.data.published_date?.valueOf() ?? 0) - (a.data.published_date?.valueOf() ?? 0)
);

const cards = await Promise.all(
  posts.map(async (p) => {
    const cat = p.data.category ? await getEntry(p.data.category) : undefined;
    return {
      title: p.data.title,
      href: blogHref(p),
      excerpt: p.data.excerpt,
      date: p.data.published_date,
      category: cat?.data.title,
      image: p.data.featured_image,
    };
  })
);

const crumbs = [{ label: 'Home', href: '/' }, { label: 'Blog' }];
---

<BaseLayout
  title="Blog | CalcFree"
  description="Guides and explainers on tax, money and home-project costs — written to be useful, with sources you can check."
>
  <SchemaBreadcrumb slot="head" items={crumbs} />
  <Breadcrumbs items={crumbs} />

  <section class="section" style="padding-top: var(--sp-4);">
    <div class="container">
      <h1>Blog</h1>
      <p class="lead" style="margin-top: var(--sp-3);">
        Practical guides on tax, money and home-project costs.
      </p>

      {cards.length > 0 ? (
        <div class="grid grid-3" style="margin-top: var(--sp-6);">
          {cards.map((p) => (
            <BlogCard title={p.title} href={p.href} excerpt={p.excerpt} date={p.date} category={p.category} image={p.image} />
          ))}
        </div>
      ) : (
        <p style="margin-top: var(--sp-5);">No posts published yet. Check back soon.</p>
      )}
    </div>
  </section>
</BaseLayout>
