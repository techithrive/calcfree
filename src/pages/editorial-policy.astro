---
/**
 * Static page: editorial-policy. Content comes from src/content/pages/editorial-policy.md.
 * Fails clearly if the content file is missing (no fake thin page).
 */
import { getEntry, render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';
import SchemaBreadcrumb from '../components/seo/SchemaBreadcrumb.astro';

const entry = await getEntry('pages', 'editorial-policy');
if (!entry) {
  throw new Error("Missing content: src/content/pages/editorial-policy.md is required for /editorial-policy/.");
}
const { Content } = await render(entry);
const crumbs = [{ label: 'Home', href: '/' }, { label: entry.data.title }];
const seo = {
  title: entry.data.seo_title ?? `${entry.data.title} | CalcFree`,
  description: entry.data.meta_description,
};
---

<PageLayout seo={seo} breadcrumbs={crumbs} title={entry.data.title} lastUpdated={entry.data.last_updated}>
  <SchemaBreadcrumb slot="head" items={crumbs} />
  <Content />
</PageLayout>
